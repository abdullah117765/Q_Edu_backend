# Set NODE_ENV=production in deployment environments to disable Swagger and other dev tooling
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://root:root@localhost:3306/qedu
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_TTL_SECONDS=604800
AUTH_ACCESS_TOKEN_COOKIE_NAME=qedu_access_token
AUTH_REFRESH_TOKEN_COOKIE_NAME=qedu_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=false
SMTP_FROM=no-reply@example.com
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_API_BASE_URL=https://api.zoom.us/v2
ZOOM_OAUTH_URL=https://zoom.us/oauth/token
ZOOM_CLASS_CREDIT_COST=1
ACADEMY_OWNER_INITIAL_FREE_CREDITS=100
CORS_ALLOWED_ORIGINS=http://localhost:5173
FILE_STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./storage/uploads
FILE_STORAGE_PUBLIC_ROOT=/storage
FILE_STORAGE_PUBLIC_URL=

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Dev: run `npm run stripe:listen` — the CLI prints the whsec_... secret on startup
STRIPE_WEBHOOK_SECRET=whsec_replace_with_cli_secret
STRIPE_API_VERSION=2024-06-20
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/academy/billing
PLATFORM_FEE_PERCENT=10

# Super Admin (auto-seeded on startup)
SUPER_ADMIN_EMAIL=super@example.com
SUPER_ADMIN_PASSWORD=change-me
SUPER_ADMIN_FIRST_NAME=Platform
SUPER_ADMIN_LAST_NAME=Admin
