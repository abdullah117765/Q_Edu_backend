generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ACADEMY_OWNER
  TEACHER
  STUDENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClassStatus {
  UPCOMING
  ONGOING
  ENDED
  CANCELLED
}

enum ClassParticipantRole {
  TEACHER
  STUDENT
  GUEST
}

enum AcademyMemberRole {
  TEACHER
  STUDENT
}

enum AcademyMembershipStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum AcademyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ZoomCreditTransactionType {
  CREDIT
  DEBIT
  TRANSFER_OUT
  TRANSFER_IN
}

enum ZoomCreditAuditAction {
  CREATED
  UPDATED
  REVERSED
}

enum ResourceVisibility {
  PRIVATE
  ACADEMY
  PUBLIC
}

model User {
  id                                 String                  @id @default(cuid())
  email                              String                  @unique
  password                           String
  firstName                          String
  lastName                           String?
  phoneNumber                        String
  gender                             String?
  bio                                String?
  dateOfBirth                        DateTime?
  addressStreet                      String?
  addressHouse                       String?
  addressCity                        String?
  addressState                       String?
  addressCountry                     String?
  profilePhotoKey                    String?
  profilePhotoUrl                    String?
  role                               Role                    @default(STUDENT)
  status                             UserStatus              @default(PENDING)
  rejectionReason                    String?
  isActive                           Boolean                 @default(false)
  zoomUserId                         String?                 @unique
  createdAt                          DateTime                @default(now())
  updatedAt                          DateTime                @updatedAt
  refreshTokens                      RefreshToken[]
  passwordResetTokens                PasswordResetToken[]
  emailVerification                  EmailVerificationToken?
  teachingClasses                    Class[]
  classParticipants                  ClassParticipant[]
  zoomCreditBalance                  ZoomCreditBalance?
  zoomCreditTransactions             ZoomCreditTransaction[] @relation("ZoomCreditOwner")
  zoomCreditCounterpartyTransactions ZoomCreditTransaction[] @relation("ZoomCreditCounterparty")
  zoomCreditAuditLogs                ZoomCreditAuditLog[]    @relation("ZoomCreditAuditActor")
  resources                          Resource[]
  payments                           Payment[]
  subscriptions                      Subscription[]
  stripeCustomer                     StripeCustomer?
  updatedPlatformSettings            PlatformSetting[]       @relation("PlatformSettingsUpdatedBy")
  academySettings                    AcademySetting[]
  ownedAcademy                       Academy?                @relation("AcademyOwner")
  academyMemberships                 AcademyMembership[]
  membershipActions                  AcademyMembership[]     @relation("AcademyMembershipActionedBy")
  reviewedAcademies                  Academy[]               @relation("AcademyReviewedBy")
  notifications                      Notification[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([firstName])
  @@index([lastName])
}

enum NotificationType {
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_CANCELLED
  COUPON_REDEEMED
  MEMBERSHIP_PENDING
  MEMBERSHIP_APPROVED
  MEMBERSHIP_REJECTED
  GENERIC
}

enum ContactMessageStatus {
  NEW
  IN_REVIEW
  RESOLVED
  SPAM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?          @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String               @db.Text
  status    ContactMessageStatus @default(NEW)
  sourceUrl String?
  metadata  Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model RefreshToken {
  id          String   @id @default(cuid())
  hashedToken String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  otpHash    String
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  otpHash    String
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
}

model Academy {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  ownerId     String              @unique
  profileCompleted Boolean        @default(false)
  status      AcademyStatus       @default(PENDING)
  rejectionReason String?
  reviewedById String?
  reviewedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  owner       User                @relation("AcademyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewedBy  User?               @relation("AcademyReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  memberships AcademyMembership[]
  classes     Class[]
  resources   Resource[]

  @@index([name])
  @@index([ownerId])
  @@index([status])
}

model AcademyMembership {
  id           String                  @id @default(cuid())
  academyId    String
  userId       String
  role         AcademyMemberRole
  status       AcademyMembershipStatus @default(PENDING)
  requestedAt  DateTime                @default(now())
  respondedAt  DateTime?
  reason       String?
  actionedById String?
  academy      Academy                 @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionedBy   User?                   @relation("AcademyMembershipActionedBy", fields: [actionedById], references: [id], onDelete: SetNull)

  @@unique([academyId, userId])
  @@index([userId, status])
  @@index([academyId, status])
  @@index([status])
}

model Class {
  id                     String                  @id @default(cuid())
  title                  String
  description            String?
  academyId              String
  teacherId              String
  teacher                User                    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  status                 ClassStatus             @default(UPCOMING)
  scheduledStart         DateTime
  scheduledEnd           DateTime
  durationMinutes        Int
  timezone               String
  creditsConsumed        Int?
  zoomMeetingId          String?                 @unique
  zoomHostId             String?
  zoomJoinUrl            String?                @db.VarChar(512)
  zoomStartUrl           String?                @db.VarChar(512)
  zoomPassword           String?
  zoomUuid               String?
  metadata               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  participants           ClassParticipant[]
  zoomCreditTransactions ZoomCreditTransaction[]
  resources              Resource[]
  academy                Academy                 @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([academyId])
  @@index([scheduledStart])
  @@index([status, scheduledStart])
  @@index([zoomMeetingId])
}

model ClassParticipant {
  id                  String               @id @default(cuid())
  classId             String
  userId              String?
  zoomParticipantUuid String?
  email               String?
  displayName         String?
  role                ClassParticipantRole @default(STUDENT)
  joinTime            DateTime?
  leaveTime           DateTime?
  durationSeconds     Int?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  class               Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([classId, zoomParticipantUuid])
  @@index([classId])
  @@index([userId])
  @@index([zoomParticipantUuid])
}

model ZoomCreditBalance {
  userId    String   @id
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ZoomCreditTransaction {
  id             String                    @id @default(cuid())
  userId         String
  relatedUserId  String?
  classId        String?
  type           ZoomCreditTransactionType
  amount         Int
  runningBalance Int
  reason         String?
  metadata       Json?
  createdAt      DateTime                  @default(now())
  user           User                      @relation("ZoomCreditOwner", fields: [userId], references: [id], onDelete: Cascade)
  relatedUser    User?                     @relation("ZoomCreditCounterparty", fields: [relatedUserId], references: [id], onDelete: SetNull)
  class          Class?                    @relation(fields: [classId], references: [id], onDelete: SetNull)
  auditLogs      ZoomCreditAuditLog[]

  @@index([userId, createdAt])
  @@index([classId])
  @@index([relatedUserId])
}

model ZoomCreditAuditLog {
  id            String                @id @default(cuid())
  transactionId String
  actorId       String?
  action        ZoomCreditAuditAction @default(CREATED)
  details       Json?
  createdAt     DateTime              @default(now())
  transaction   ZoomCreditTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  actor         User?                 @relation("ZoomCreditAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([actorId])
}

model Resource {
  id          String             @id @default(cuid())
  title       String
  description String?
  fileKey     String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  fileType    String?
  uploaderId  String
  classId     String?
  academyId   String?
  visibility  ResourceVisibility @default(ACADEMY)
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  uploader    User               @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  class       Class?             @relation(fields: [classId], references: [id], onDelete: SetNull)
  academy     Academy?           @relation(fields: [academyId], references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([classId])
  @@index([academyId])
  @@index([visibility])
}

model Payment {
  id                 String   @id @default(cuid())
  userId             String
  amount             Decimal  @db.Decimal(12, 2)
  platformFeeAmount  Decimal? @db.Decimal(12, 2)
  netAmount          Decimal? @db.Decimal(12, 2)
  currency           String   @default("USD")
  provider           String
  status             String
  reference          String?
  description        String?
  packageId          String?
  subscriptionId     String?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  package            ZoomCreditPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  subscription       Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([provider])
  @@index([packageId])
  @@index([subscriptionId])
}

enum ZoomCreditPackageBillingType {
  ONE_TIME
  PER_MINUTE
}

model ZoomCreditPackage {
  id              String                       @id @default(cuid())
  name            String
  description     String?
  credits         Int
  priceCents      Int
  currency        String                       @default("USD")
  billingType     ZoomCreditPackageBillingType @default(ONE_TIME)
  bonusCredits    Int                          @default(0)
  highlight       Boolean                      @default(false)
  active          Boolean                      @default(true)
  sortOrder       Int                          @default(0)
  stripeProductId String?
  stripePriceId   String?                      @unique
  metadata        Json?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  payments        Payment[]

  @@index([active])
  @@index([sortOrder])
}

enum SubscriptionInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

model SubscriptionPlan {
  id                  String                @id @default(cuid())
  name                String
  description         String?
  tier                String
  priceCents          Int
  currency            String                @default("USD")
  interval            SubscriptionInterval  @default(MONTHLY)
  monthlyClassMinutes Int                   @default(0)
  monthlyCredits      Int                   @default(0)
  maxTeachers         Int?
  maxStudents         Int?
  features            Json?
  highlight           Boolean               @default(false)
  active              Boolean               @default(true)
  sortOrder           Int                   @default(0)
  stripeProductId     String?
  stripePriceId       String?               @unique
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  subscriptions       Subscription[]

  @@index([active])
  @@index([tier])
  @@index([interval])
}

model Subscription {
  id                   String              @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus  @default(INCOMPLETE)
  stripeSubscriptionId String?             @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  canceledAt           DateTime?
  trialEnd             DateTime?
  metadata             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan    @relation(fields: [planId], references: [id])
  payments             Payment[]

  @@index([userId])
  @@index([planId])
  @@index([status])
}

model StripeCustomer {
  userId           String   @id
  stripeCustomerId String   @unique
  email            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime?
  payload     Json
  receivedAt  DateTime @default(now())

  @@index([type])
  @@index([processedAt])
}

enum CouponDiscountType {
  PERCENT
  AMOUNT
}

enum CouponDuration {
  ONCE
  REPEATING
  FOREVER
}

enum CouponAppliesTo {
  ALL
  PACKAGES
  PLANS
}

model Coupon {
  id              String              @id @default(cuid())
  code            String              @unique
  name            String
  description     String?
  discountType    CouponDiscountType  @default(PERCENT)
  percentOff      Int?
  amountOffCents  Int?
  currency        String              @default("USD")
  duration        CouponDuration      @default(ONCE)
  durationMonths  Int?
  appliesTo       CouponAppliesTo     @default(ALL)
  maxRedemptions  Int?
  timesRedeemed   Int                 @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  active          Boolean             @default(true)
  highlight       Boolean             @default(false)
  marketingTitle  String?
  marketingBody   String?
  stripeCouponId  String?             @unique
  stripePromotionCodeId String?       @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  redemptions     CouponRedemption[]

  @@index([active])
  @@index([expiresAt])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  userId     String?
  paymentId  String?
  amountOffCents Int?
  createdAt  DateTime @default(now())
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
}

model PlatformSetting {
  key         String   @id
  value       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("PlatformSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}

model AcademySetting {
  id        String   @id @default(cuid())
  ownerId   String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, key])
  @@index([ownerId])
}
