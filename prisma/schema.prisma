generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ACADEMY_OWNER
  TEACHER
  STUDENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClassStatus {
  UPCOMING
  ONGOING
  ENDED
  CANCELLED
}

enum ClassParticipantRole {
  TEACHER
  STUDENT
  GUEST
}

enum AcademyMemberRole {
  TEACHER
  STUDENT
}

enum AcademyMembershipStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum AcademyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ZoomCreditTransactionType {
  CREDIT
  DEBIT
  TRANSFER_OUT
  TRANSFER_IN
}

enum ZoomCreditAuditAction {
  CREATED
  UPDATED
  REVERSED
}

enum ResourceVisibility {
  PRIVATE
  ACADEMY
  PUBLIC
}

model User {
  id                                 String                  @id @default(cuid())
  email                              String                  @unique
  password                           String
  firstName                          String
  lastName                           String?
  phoneNumber                        String
  gender                             String?
  bio                                String?
  dateOfBirth                        DateTime?
  addressStreet                      String?
  addressHouse                       String?
  addressCity                        String?
  addressState                       String?
  addressCountry                     String?
  profilePhotoKey                    String?
  profilePhotoUrl                    String?
  role                               Role                    @default(STUDENT)
  status                             UserStatus              @default(PENDING)
  rejectionReason                    String?
  isActive                           Boolean                 @default(false)
  zoomUserId                         String?                 @unique
  createdAt                          DateTime                @default(now())
  updatedAt                          DateTime                @updatedAt
  refreshTokens                      RefreshToken[]
  passwordResetTokens                PasswordResetToken[]
  emailVerification                  EmailVerificationToken?
  teachingClasses                    Class[]
  classParticipants                  ClassParticipant[]
  zoomCreditBalance                  ZoomCreditBalance?
  zoomCreditTransactions             ZoomCreditTransaction[] @relation("ZoomCreditOwner")
  zoomCreditCounterpartyTransactions ZoomCreditTransaction[] @relation("ZoomCreditCounterparty")
  zoomCreditAuditLogs                ZoomCreditAuditLog[]    @relation("ZoomCreditAuditActor")
  resources                          Resource[]
  payments                           Payment[]
  updatedPlatformSettings            PlatformSetting[]       @relation("PlatformSettingsUpdatedBy")
  academySettings                    AcademySetting[]
  ownedAcademy                       Academy?                @relation("AcademyOwner")
  academyMemberships                 AcademyMembership[]
  membershipActions                  AcademyMembership[]     @relation("AcademyMembershipActionedBy")
  reviewedAcademies                  Academy[]               @relation("AcademyReviewedBy")

  @@index([role])
  @@index([status])
}

model RefreshToken {
  id          String   @id @default(cuid())
  hashedToken String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  otpHash    String
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  otpHash    String
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
}

model Academy {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  ownerId     String              @unique
  profileCompleted Boolean        @default(false)
  status      AcademyStatus       @default(PENDING)
  rejectionReason String?
  reviewedById String?
  reviewedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  owner       User                @relation("AcademyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewedBy  User?               @relation("AcademyReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  memberships AcademyMembership[]
  classes     Class[]
  resources   Resource[]

  @@index([name])
  @@index([ownerId])
  @@index([status])
}

model AcademyMembership {
  id           String                  @id @default(cuid())
  academyId    String
  userId       String
  role         AcademyMemberRole
  status       AcademyMembershipStatus @default(PENDING)
  requestedAt  DateTime                @default(now())
  respondedAt  DateTime?
  reason       String?
  actionedById String?
  academy      Academy                 @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionedBy   User?                   @relation("AcademyMembershipActionedBy", fields: [actionedById], references: [id], onDelete: SetNull)

  @@unique([academyId, userId])
  @@index([userId, status])
  @@index([academyId, status])
  @@index([status])
}

model Class {
  id                     String                  @id @default(cuid())
  title                  String
  description            String?
  academyId              String
  teacherId              String
  teacher                User                    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  status                 ClassStatus             @default(UPCOMING)
  scheduledStart         DateTime
  scheduledEnd           DateTime
  durationMinutes        Int
  timezone               String
  creditsConsumed        Int?
  zoomMeetingId          String?                 @unique
  zoomHostId             String?
  zoomJoinUrl            String?
  zoomStartUrl           String?
  zoomPassword           String?
  zoomUuid               String?
  metadata               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  participants           ClassParticipant[]
  zoomCreditTransactions ZoomCreditTransaction[]
  resources              Resource[]
  academy                Academy                 @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([academyId])
  @@index([scheduledStart])
  @@index([status, scheduledStart])
  @@index([zoomMeetingId])
}

model ClassParticipant {
  id                  String               @id @default(cuid())
  classId             String
  userId              String?
  zoomParticipantUuid String?
  email               String?
  displayName         String?
  role                ClassParticipantRole @default(STUDENT)
  joinTime            DateTime?
  leaveTime           DateTime?
  durationSeconds     Int?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  class               Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([classId, zoomParticipantUuid])
  @@index([classId])
  @@index([userId])
  @@index([zoomParticipantUuid])
}

model ZoomCreditBalance {
  userId    String   @id
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ZoomCreditTransaction {
  id             String                    @id @default(cuid())
  userId         String
  relatedUserId  String?
  classId        String?
  type           ZoomCreditTransactionType
  amount         Int
  runningBalance Int
  reason         String?
  metadata       Json?
  createdAt      DateTime                  @default(now())
  user           User                      @relation("ZoomCreditOwner", fields: [userId], references: [id], onDelete: Cascade)
  relatedUser    User?                     @relation("ZoomCreditCounterparty", fields: [relatedUserId], references: [id], onDelete: SetNull)
  class          Class?                    @relation(fields: [classId], references: [id], onDelete: SetNull)
  auditLogs      ZoomCreditAuditLog[]

  @@index([userId, createdAt])
  @@index([classId])
  @@index([relatedUserId])
}

model ZoomCreditAuditLog {
  id            String                @id @default(cuid())
  transactionId String
  actorId       String?
  action        ZoomCreditAuditAction @default(CREATED)
  details       Json?
  createdAt     DateTime              @default(now())
  transaction   ZoomCreditTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  actor         User?                 @relation("ZoomCreditAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([actorId])
}

model Resource {
  id          String             @id @default(cuid())
  title       String
  description String?
  fileKey     String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  fileType    String?
  uploaderId  String
  classId     String?
  academyId   String?
  visibility  ResourceVisibility @default(ACADEMY)
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  uploader    User               @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  class       Class?             @relation(fields: [classId], references: [id], onDelete: SetNull)
  academy     Academy?           @relation(fields: [academyId], references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([classId])
  @@index([academyId])
  @@index([visibility])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("USD")
  provider  String
  status    String
  reference String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

model PlatformSetting {
  key         String   @id
  value       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("PlatformSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}

model AcademySetting {
  id        String   @id @default(cuid())
  ownerId   String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, key])
  @@index([ownerId])
}
